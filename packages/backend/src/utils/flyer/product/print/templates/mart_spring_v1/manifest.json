{
  "id": "mart_spring_v1",
  "version": "1.0.0",
  "name": "마트 봄세일 A3 세로형",
  "description": "샘플1(TEST THE MARKET 봄세일의특가전) 기준 1:1 재현. 4섹션 구조: 매장헤더 → 히어로타이틀 → 메인4칸 → 추천5칸 → FRESH 카테고리 좌우 2분할.",
  "industry": "mart",
  "season": "spring",
  "paper": { "size": "A3", "orientation": "portrait" },
  "pages": 1,
  "assets": {
    "html": "template.html",
    "css": "template.css",
    "preview": "preview.png"
  },
  "tokens": "../../design-tokens.json",

  "slots": [
    {
      "id": "store_masthead",
      "type": "store_header",
      "required": true,
      "includes": ["logo", "name", "hours", "phone", "address", "map", "qr_online"],
      "layout": "3col",
      "position": { "css": ".masthead" },
      "note": "샘플1 상단 3분할: 매장정보|약도|전화+QR+온라인몰 배너"
    },
    {
      "id": "hero_title",
      "type": "typography",
      "required": true,
      "editable": true,
      "maxLength": 14,
      "fallback": "봄세일의특가전",
      "effects": ["gradient", "outline", "illustration"],
      "aiGenerate": {
        "prompt": "마트 봄 시즌 세일 메인 카피, 8~14자. 컬러풀 일러스트 타이포 스타일.",
        "variants": 3
      },
      "position": { "css": ".hero-title" }
    },
    {
      "id": "hero_subcopy",
      "type": "text",
      "required": false,
      "editable": true,
      "maxLength": 40,
      "fallback": "봄날 혜택 봄맞이 인기상품 특가 퍼레이드!",
      "aiGenerate": {
        "prompt": "히어로 서브카피, 20~40자. 활기찬 톤.",
        "variants": 3
      },
      "position": { "css": ".hero-subcopy" }
    },
    {
      "id": "section_banner_main",
      "type": "section_banner",
      "required": true,
      "label": "지금 딱 필요한 상품들만 모아 가!",
      "svgAsset": "banners/save_wallet_red.svg",
      "editableText": true,
      "position": { "css": ".section-banner-main" }
    },
    {
      "id": "main_grid",
      "type": "product_grid",
      "required": true,
      "cols": 4, "rows": 1,
      "minItems": 3, "maxItems": 4,
      "selection": {
        "mode": "highest_discount",
        "filter": { "promoType": "main" }
      },
      "cardVariant": "main",
      "overflow": "shrink",
      "position": { "css": ".main-grid" },
      "note": "샘플1 최상단 메인 4칸 — 살구색 배경 + 주황 테두리 + 큰 가격 빨강"
    },
    {
      "id": "section_banner_recommend",
      "type": "section_banner",
      "required": true,
      "label": "알뜰쇼핑 찬스를 잡으세요 강력추천!",
      "svgAsset": "banners/save_wallet_green.svg",
      "editableText": true,
      "position": { "css": ".section-banner-recommend" }
    },
    {
      "id": "recommend_grid",
      "type": "product_grid",
      "required": true,
      "cols": 5, "rows": 1,
      "minItems": 4, "maxItems": 5,
      "selection": {
        "mode": "highest_discount",
        "filter": { "promoType": "sub" }
      },
      "cardVariant": "sub",
      "overflow": "shrink",
      "position": { "css": ".recommend-grid" },
      "note": "샘플1 2번째 섹션 5칸 — 연두 배경 + 초록 테두리 + 정상가 취소선 강조"
    },
    {
      "id": "section_banner_fresh",
      "type": "section_banner",
      "required": true,
      "label": "자연에서 신선한 그대로",
      "sublabel": "신선코너 1차식품 일자별 파격세일",
      "svgAsset": "banners/fresh_stripe_red.svg",
      "editableText": true,
      "position": { "css": ".section-banner-fresh" }
    },
    {
      "id": "fresh_left",
      "type": "category_grid",
      "required": true,
      "cols": 3, "rows": 3,
      "category": {
        "mode": "auto",
        "prefer": ["축산", "정육", "한우", "돼지고기", "닭고기"]
      },
      "cardVariant": "fresh",
      "stripePattern": true,
      "overflow": "shrink",
      "position": { "css": ".fresh-left" },
      "note": "좌측 카테고리 — 샘플1은 지그재그 노랑/연두 배경"
    },
    {
      "id": "fresh_right",
      "type": "category_grid",
      "required": true,
      "cols": 3, "rows": 3,
      "category": {
        "mode": "auto",
        "prefer": ["수산", "해산물", "과일", "청과", "채소"]
      },
      "cardVariant": "fresh",
      "stripePattern": true,
      "overflow": "shrink",
      "position": { "css": ".fresh-right" }
    },
    {
      "id": "footer_notice",
      "type": "footer_notice",
      "required": false,
      "editable": true,
      "fallback": "행사상품은 조기 품절될 수 있습니다. 사진은 이미지컷이며 실제와 다를 수 있습니다. 단가 사정에 따라 냉동으로 대체될 수 있습니다. 먹거리 상품은 유통기한 확인하세요.",
      "position": { "css": ".footer-notice" }
    },
    {
      "id": "deco_flower_top",
      "type": "decoration",
      "required": false,
      "svgAsset": "deco/spring_flower_pink.svg",
      "static": true,
      "position": { "css": ".deco-flower-top" }
    }
  ]
}
