{
  "id": "mart_spring_v1",
  "version": "2.0.0",
  "name": "마트 봄세일 2절 세로 (Line B 친근 파스텔 모듈러)",
  "description": "한줄전단AI 고유 디자인 — 2절(545×788mm) 한국 동네마트 실무 표준. 샘플1 추종 폐기, 매거진 모듈러 레이아웃. 섹션 번호(01/02/03/04) + 4카테고리 블록(축산/수산/청과/주류).",
  "industry": "mart",
  "season": "spring",
  "paper": { "size": "j2", "orientation": "portrait" },
  "pages": 1,
  "assets": {
    "html": "template.html",
    "css": "template.css",
    "preview": "preview.png"
  },
  "tokens": "../../design-tokens.json",

  "slots": [
    {
      "id": "masthead",
      "type": "store_header",
      "required": true,
      "includes": ["aiMark", "store", "qr"],
      "layout": "horizontal_bar",
      "position": { "css": ".masthead" },
      "note": "얇은 수평 바: 좌측 AI마크+매장정보, 우측 QR (샘플1 3분할과 다른 모던 바 스타일)"
    },
    {
      "id": "hero_title",
      "type": "typography",
      "required": true,
      "editable": true,
      "maxLength": 16,
      "fallback": "봄 세일",
      "effects": [],
      "aiGenerate": {
        "prompt": "마트 봄 시즌 세일 메인 카피, 2~8자 간결, 매거진 타이포 느낌",
        "variants": 3
      },
      "position": { "css": ".hero-title" }
    },
    {
      "id": "hero_period",
      "type": "text",
      "required": false,
      "editable": true,
      "fallback": "04.17 (목) ~ 04.23 (수)",
      "position": { "css": ".hero-period" }
    },
    {
      "id": "hero_subcopy",
      "type": "text",
      "required": false,
      "editable": true,
      "maxLength": 60,
      "fallback": "봄맞이 인기상품 알뜰 가격으로 만나보세요",
      "aiGenerate": {
        "prompt": "히어로 서브카피, 20~50자, 차분하고 신뢰감 있는 톤",
        "variants": 3
      },
      "position": { "css": ".hero-subcopy" }
    },
    {
      "id": "section_main",
      "type": "section_banner",
      "required": true,
      "label": "오늘의 특가",
      "number": "01",
      "position": { "css": ".section-main-header" }
    },
    {
      "id": "main_grid", "type": "product_grid", "required": true,
      "cols": 4, "rows": 2, "minItems": 6, "maxItems": 8,
      "selection": { "mode": "highest_discount", "filter": { "promoType": "main" } },
      "cardVariant": "main", "overflow": "shrink", "position": { "css": ".main-grid" }
    },
    {
      "id": "section_recommend", "type": "section_banner", "required": true,
      "label": "베스트 픽", "number": "02",
      "position": { "css": ".section-recommend-header" }
    },
    {
      "id": "recommend_grid", "type": "product_grid", "required": true,
      "cols": 6, "rows": 2, "minItems": 8, "maxItems": 12,
      "selection": { "mode": "highest_discount", "filter": { "promoType": "sub" } },
      "cardVariant": "sub", "overflow": "shrink", "position": { "css": ".recommend-grid" }
    },
    {
      "id": "section_fresh", "type": "section_banner", "required": true,
      "label": "신선 코너", "sublabel": "매일 들어오는 신선한 상품", "number": "03",
      "position": { "css": ".section-fresh-header" }
    },
    {
      "id": "fresh_block_1", "type": "category_grid", "required": true,
      "cols": 4, "rows": 3, "maxItems": 12,
      "category": { "mode": "auto", "prefer": ["축산", "정육", "한우", "돼지고기", "닭고기"] },
      "cardVariant": "fresh", "overflow": "shrink", "position": { "css": ".fresh-block-1" }
    },
    {
      "id": "fresh_block_2", "type": "category_grid", "required": true,
      "cols": 4, "rows": 3, "maxItems": 12,
      "category": { "mode": "auto", "prefer": ["수산", "해산물", "생선"] },
      "cardVariant": "fresh", "overflow": "shrink", "position": { "css": ".fresh-block-2" }
    },
    {
      "id": "fresh_block_3", "type": "category_grid", "required": true,
      "cols": 4, "rows": 3, "maxItems": 12,
      "category": { "mode": "auto", "prefer": ["청과", "과일", "채소", "야채"] },
      "cardVariant": "fresh", "overflow": "shrink", "position": { "css": ".fresh-block-3" }
    },
    {
      "id": "fresh_block_4", "type": "category_grid", "required": true,
      "cols": 4, "rows": 3, "maxItems": 12,
      "category": { "mode": "auto", "prefer": ["주류", "술", "와인", "음료"] },
      "cardVariant": "fresh", "overflow": "shrink", "position": { "css": ".fresh-block-4" }
    },
    {
      "id": "footer_notice",
      "type": "footer_notice",
      "required": false,
      "editable": true,
      "fallback": "행사상품은 조기 품절될 수 있습니다. 사진은 이미지컷이며 실제와 다를 수 있습니다.",
      "position": { "css": ".footer-notice" }
    },
    {
      "id": "footer_brand",
      "type": "text",
      "required": false,
      "fallback": "🔵 한줄로 · hanjul.ai",
      "position": { "css": ".footer-brand" }
    }
  ]
}
