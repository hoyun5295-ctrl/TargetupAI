{
  "id": "mart_weekend_v1",
  "version": "1.0.0",
  "name": "마트 주말대박 2절 세로 (퍼플+옐로 일렉트릭)",
  "description": "주말 한정 특가 전용. 퍼플 + 옐로 + 시안 일렉트릭 컬러 조합. 뾰족한 도형, 네온 강조, 주말 한정 임팩트. 금-일 3일 한정 행사 주간지.",
  "industry": "mart",
  "season": "general",
  "paper": { "size": "j2", "orientation": "portrait" },
  "pages": 1,
  "assets": { "html": "template.html", "css": "template.css", "preview": "preview.png" },
  "slots": [
    { "id": "masthead", "type": "store_header", "required": true, "includes": ["aiMark", "store", "qr"], "position": { "css": ".masthead" } },
    { "id": "hero_title", "type": "typography", "required": true, "editable": true, "maxLength": 16, "fallback": "주말 대박", "position": { "css": ".hero-title" } },
    { "id": "hero_period", "type": "text", "required": false, "editable": true, "fallback": "04.19 (토) ~ 04.21 (월)", "position": { "css": ".hero-period" } },
    { "id": "hero_subcopy", "type": "text", "required": false, "editable": true, "maxLength": 60, "fallback": "주말에만 만나는 특별가, 단 3일 한정", "position": { "css": ".hero-subcopy" } },

    { "id": "section_main", "type": "section_banner", "required": true, "label": "주말 SPECIAL", "number": "01", "position": { "css": ".section-main-header" } },
    { "id": "main_grid", "type": "product_grid", "required": true, "cols": 4, "rows": 2, "minItems": 6, "maxItems": 8,
      "selection": { "mode": "highest_discount", "filter": { "promoType": "main" } }, "cardVariant": "main", "overflow": "shrink", "position": { "css": ".main-grid" } },

    { "id": "section_recommend", "type": "section_banner", "required": true, "label": "WEEKEND BEST", "number": "02", "position": { "css": ".section-recommend-header" } },
    { "id": "recommend_grid", "type": "product_grid", "required": true, "cols": 6, "rows": 2, "minItems": 8, "maxItems": 12,
      "selection": { "mode": "highest_discount", "filter": { "promoType": "sub" } }, "cardVariant": "sub", "overflow": "shrink", "position": { "css": ".recommend-grid" } },

    { "id": "section_fresh", "type": "section_banner", "required": true, "label": "신선 FRESH PARTY", "sublabel": "주말맞이 신선 특가", "number": "03", "position": { "css": ".section-fresh-header" } },
    { "id": "fresh_block_1", "type": "category_grid", "required": true, "cols": 4, "rows": 3, "maxItems": 12,
      "category": { "mode": "auto", "prefer": ["축산", "정육", "한우", "돼지고기", "닭고기"] }, "cardVariant": "fresh", "overflow": "shrink", "position": { "css": ".fresh-block-1" } },
    { "id": "fresh_block_2", "type": "category_grid", "required": true, "cols": 4, "rows": 3, "maxItems": 12,
      "category": { "mode": "auto", "prefer": ["수산", "해산물", "생선"] }, "cardVariant": "fresh", "overflow": "shrink", "position": { "css": ".fresh-block-2" } },
    { "id": "fresh_block_3", "type": "category_grid", "required": true, "cols": 4, "rows": 3, "maxItems": 12,
      "category": { "mode": "auto", "prefer": ["청과", "과일", "채소", "야채"] }, "cardVariant": "fresh", "overflow": "shrink", "position": { "css": ".fresh-block-3" } },
    { "id": "fresh_block_4", "type": "category_grid", "required": true, "cols": 4, "rows": 3, "maxItems": 12,
      "category": { "mode": "auto", "prefer": ["주류", "술", "와인", "음료"] }, "cardVariant": "fresh", "overflow": "shrink", "position": { "css": ".fresh-block-4" } },

    { "id": "footer_notice", "type": "footer_notice", "required": false, "editable": true, "fallback": "행사상품은 조기 품절될 수 있습니다. 사진은 이미지컷이며 실제와 다를 수 있습니다.", "position": { "css": ".footer-notice" } },
    { "id": "footer_brand", "type": "text", "required": false, "fallback": "⚡ 한줄로 · hanjul.ai", "position": { "css": ".footer-brand" } }
  ]
}
