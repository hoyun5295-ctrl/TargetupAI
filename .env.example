# Target-UP 환경 변수

# ===========================================
# Database
# ===========================================
DATABASE_URL=postgresql://targetup:targetup_dev_password@localhost:5432/targetup

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# JWT 인증
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# ===========================================
# 서버 설정
# ===========================================
PORT=3000
NODE_ENV=development

# ===========================================
# SMS/MMS API (통신사)
# ===========================================
SMS_API_URL=https://api.sms-provider.com
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret

# ===========================================
# 카카오 비즈메시지 API (레거시 — D130 이전 참조용)
# ===========================================
KAKAO_API_URL=https://api.kakao.com/bizmessage
KAKAO_API_KEY=your-kakao-api-key
KAKAO_SENDER_KEY=your-kakao-sender-key

# ===========================================
# 휴머스온 IMC (알림톡/브랜드메시지 관리 API, D130+)
# 월요일 수령 후 주입 (Phase 0: API KEY / 샌드박스 URL / HMAC / 웹훅 IP)
# ===========================================
# 운영/샌드박스 환경 스위치 (STG / PRD)
IMC_ENV=STG

# API Key (cs_imc@humuson.com 발급)
IMC_API_KEY=                              # 운영 키 — 월요일 수령
IMC_API_KEY_SANDBOX=APIKEY-HUMUSON-0001   # 공개 샌드박스 키 (변경 가능)

# Base URL (환경별)
IMC_BASE_URL_PRD=https://imc-api.humuson.com     # 운영 URL (월요일 확정)
IMC_BASE_URL_STG=http://10.147.1.109:28000       # 샌드박스 (내부망 / VPN 필요 가능)

# 웹훅 보안
IMC_WEBHOOK_ALLOWED_IPS=                  # 휴머스온 송신 IP 목록 (쉼표 구분) — 월요일 수령
IMC_WEBHOOK_HMAC_SECRET=                  # HMAC-SHA256 검증 시크릿 — 월요일 수령

# 이미지 업로드 임시 디렉터리
IMC_UPLOAD_TMP_DIR=/tmp/imc-uploads

# ===========================================
# 080 수신거부 시스템
# ===========================================
OPT_OUT_API_URL=https://api.080-provider.com
OPT_OUT_API_KEY=your-opt-out-api-key

# ===========================================
# 알람 설정
# ===========================================
# 발송 알람 기준 건수
ALARM_THRESHOLD=30000

# ===========================================
# 파일 업로드
# ===========================================
UPLOAD_MAX_SIZE=45000
UPLOAD_PATH=./uploads

# ===========================================
# CORS — 운영 배포 시 반드시 운영 도메인 추가
# ===========================================
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://hanjul.ai,https://www.hanjul.ai,https://app.hanjul.ai,https://sys.hanjullo.com,https://hanjul-flyer.kr,https://www.hanjul-flyer.kr,https://hanjul-flyer.com,https://www.hanjul-flyer.com,https://hanjul-flyer.co.kr,https://www.hanjul-flyer.co.kr
