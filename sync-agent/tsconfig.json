{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": "./src",
    "paths": {
      "@config/*": ["config/*"],
      "@db/*": ["db/*"],
      "@sync/*": ["sync/*"],
      "@normalize/*": ["normalize/*"],
      "@mapping/*": ["mapping/*"],
      "@api/*": ["api/*"],
      "@queue/*": ["queue/*"],
      "@logger/*": ["logger/*"],
      "@types/*": ["types/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "data", "logs"]
}
