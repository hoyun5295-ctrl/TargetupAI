# =========================================
# Sprint 4 통합 테스트용 .env
# 스케줄러 테스트를 위해 짧은 주기 설정
# =========================================

# --- Target-UP 서버 ---
SYNC_SERVER_URL=http://localhost:3000
SYNC_API_KEY=test-sync-api-key-001
SYNC_API_SECRET=test-sync-api-secret-001

# --- 고객사 DB ---
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=test_client_db
DB_USER=smsuser
DB_PASSWORD=sms123
DB_QUERY_TIMEOUT=30000
USE_MOCK=false
DRY_RUN=false

# --- 동기화 설정 (테스트용: 짧은 주기) ---
SYNC_CUSTOMER_INTERVAL=5
SYNC_PURCHASE_INTERVAL=5
SYNC_BATCH_SIZE=4000
SYNC_CUSTOMER_TABLE=CUSTOMER
SYNC_PURCHASE_TABLE=PURCHASE
SYNC_TIMESTAMP_COLUMN=updated_at

# --- Agent ---
AGENT_NAME=agent-test-sprint4
LOG_LEVEL=info

ALERT_ENABLED=false
ALERT_EMAIL_TO=
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASS=