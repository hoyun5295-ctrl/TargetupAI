# =========================================
# Sync Agent 환경변수 (.env)
# =========================================
# 이 파일을 .env로 복사하여 사용
# 실제 운영에서는 config.enc (암호화 파일)에 저장됨

# --- Target-UP 서버 ---
SYNC_SERVER_URL=https://hanjul.ai
SYNC_API_KEY=your-api-key-here
SYNC_API_SECRET=your-api-secret-here

# --- 고객사 DB ---
DB_TYPE=mssql
DB_HOST=localhost
DB_PORT=1433
DB_NAME=your_database
DB_USER=sync_reader
DB_PASSWORD=your-password-here
DB_QUERY_TIMEOUT=30000

# --- 동기화 설정 ---
SYNC_CUSTOMER_INTERVAL=60
SYNC_PURCHASE_INTERVAL=30
SYNC_BATCH_SIZE=4000
SYNC_CUSTOMER_TABLE=CUSTOMER
SYNC_PURCHASE_TABLE=PURCHASE
SYNC_TIMESTAMP_COLUMN=updated_at

# --- Agent ---
AGENT_NAME=agent-001
LOG_LEVEL=info
ENCRYPTION_KEY=your-32-char-encryption-key-here
