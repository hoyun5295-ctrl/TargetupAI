{
  "name": "sync-agent",
  "version": "1.5.1",
  "description": "Sync Agent — 고객사 로컬 DB → Target-UP 서버 자동 동기화",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "bundle": "node esbuild.config.js",
    "build:exe": "npm run bundle && pkg dist/bundle.js --targets node20-win-x64 --output release/sync-agent.exe",
    "build:linux": "npm run bundle && pkg dist/bundle.js --targets node20-linux-x64 --output release/sync-agent",
    "build:all": "npm run bundle && pkg dist/bundle.js --targets node20-win-x64 --output release/sync-agent.exe && pkg dist/bundle.js --targets node20-linux-x64 --output release/sync-agent",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "mssql": "^11.0.1",
    "mysql2": "^3.11.0",
    "node-cron": "^3.0.3",
    "node-windows": "^1.0.0-beta.8",
    "nodemailer": "^8.0.1",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "sql.js": "^1.11.0",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mssql": "^9.1.9",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.9",
    "@types/papaparse": "^5.5.2",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@yao-pkg/pkg": "^6.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "author": "INVITO",
  "license": "UNLICENSED"
}
