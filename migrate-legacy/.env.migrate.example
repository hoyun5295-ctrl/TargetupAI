# 레거시 Oracle (다우클라우드)
LEGACY_ORACLE_USER=usom_user
LEGACY_ORACLE_PASSWORD=비밀번호_입력
LEGACY_ORACLE_DSN=호스트:포트/서비스명

# 한줄로 PostgreSQL (상용 서버)
# 서버 PG는 외부 직접접근이 막혀있을 가능성 높음 — SSH 터널 후 localhost로 연결 권장
PG_HOST=localhost
PG_PORT=5433
PG_USER=targetup
PG_PASSWORD=비밀번호_입력
PG_DATABASE=targetup

# gwss 회사/사용자 UUID (확인 완료)
GWSS_COMPANY_ID=b4e467f0-6ba4-4d1c-aca8-49ff052ffdf0
GWSS_USER_ID=9a1b4822-8f1d-45d8-b838-1d3bf9a38c20

# 테스트 모드
# true  = 조회/정규화만 실행, PG INSERT 스킵
# false = 실제 INSERT 수행
DRY_RUN=true
